<Window x:Class="PhotoPilot.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PhotoPilot.App.Views.Controls"
        Title="PhotoPilot"
        Width="1200"
        Height="750"
        MinWidth="950"
        MinHeight="650"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="86"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="30,0">

            <DockPanel VerticalAlignment="Center">
                <TextBlock DockPanel.Dock="Left"
                           Text="📸 PhotoPilot"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"/>

                <TextBlock Text="Organize memories intelligently"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Photo Library -->
<Border Margin="0,24,0,0"
        Padding="16"
        BorderBrush="{StaticResource AppBorderBrush}"
        BorderThickness="1"
        CornerRadius="10"
        Background="{StaticResource CardBackgroundBrush}">

    <StackPanel>
        <DockPanel Margin="0,0,0,14">

            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Media Library"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <TextBlock Margin="0,4,0,0"
                           Text="Photos and videos discovered in the selected folder"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <TextBlock x:Name="LibraryCountText"
                       Text="No media loaded"
                       Margin="20,0,0,0"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>

                    <StackPanel Orientation="Horizontal"
            Margin="0,18,0,14">

                        <TextBox x:Name="SearchTextBox"
             Width="260"
             Height="34"
             VerticalContentAlignment="Center"
             TextChanged="SearchTextBox_TextChanged"
             ToolTip="Search filename"/>

                        <ComboBox x:Name="MediaFilterComboBox"
              Width="140"
              Margin="12,0,0,0"
              Height="34"
              SelectionChanged="MediaFilterComboBox_SelectionChanged">

                            <ComboBoxItem IsSelected="True">
                                All
                            </ComboBoxItem>

                            <ComboBoxItem>
                                Photos
                            </ComboBoxItem>

                            <ComboBoxItem>
                                Videos
                            </ComboBoxItem>

                        </ComboBox>

                        <ComboBox x:Name="SortComboBox"
              Width="180"
              Margin="12,0,0,0"
              Height="34"
              SelectionChanged="SortComboBox_SelectionChanged">

                            <ComboBoxItem IsSelected="True">
                                Date Taken
                            </ComboBoxItem>

                            <ComboBoxItem>
                                File Name
                            </ComboBoxItem>

                            <ComboBoxItem>
                                File Size
                            </ComboBoxItem>

                        </ComboBox>

                    </StackPanel>
            
                </DockPanel>

        <Border Background="#F8FAFC"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                MinHeight="300">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="340"/>
                        </Grid.ColumnDefinitions>

                        <!-- Library grid -->
                        <Border Grid.Column="0"
            Background="#F8FAFC"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            MinHeight="420">

                            <Grid>
                                <ListBox x:Name="LibraryItemsControl"
                     Height="540"
                     Padding="10"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionMode="Single"
                     SelectionChanged="LibraryItemsControl_SelectionChanged">

                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"
                                   HorizontalAlignment="Left"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>

                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment"
                                Value="Stretch"/>

                                            <Style.Triggers>
                                                <Trigger Property="IsSelected"
                                     Value="True">
                                                    <Setter Property="Background"
                                        Value="#DBEAFE"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <controls:LibraryCardControl Width="240"
                                                     Margin="4"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Empty-library message -->
                                <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False">

                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility"
                                Value="Visible"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=LibraryItemsControl,
                                                          Path=HasItems}"
                                         Value="True">
                                                    <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <TextBlock Text="📷"
                           FontSize="40"
                           HorizontalAlignment="Center"/>

                                    <TextBlock Margin="0,10,0,0"
                           Text="No media loaded"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                                    <TextBlock Margin="0,5,0,0"
                           Text="Select a folder and run a scan to populate the library."
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Selected item details -->
                        <Border Grid.Column="2"
            Padding="18"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">

                            <Grid>
                                <!-- Empty details message -->
                                <StackPanel x:Name="NoSelectionPanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                                    <TextBlock Text="🖼"
                           FontSize="40"
                           HorizontalAlignment="Center"/>

                                    <TextBlock Margin="0,12,0,0"
                           Text="No item selected"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                                    <TextBlock Margin="0,6,0,0"
                           Text="Select a photo or video to view its details."
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Details content -->
                                <ScrollViewer x:Name="SelectedItemDetailsPanel"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">

                                    <StackPanel>
                                        <Border Height="220"
                            Background="#EEF2F7"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            ClipToBounds="True">

                                            <Grid>
                                                <Image x:Name="SelectedThumbnailImage"
                                   Stretch="Uniform"/>

                                                <TextBlock x:Name="SelectedThumbnailPlaceholder"
                                       Text="Preview unavailable"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <TextBlock x:Name="SelectedFileNameText"
                               Margin="0,18,0,0"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>

                                        <TextBlock x:Name="SelectedFilePathText"
                               Margin="0,6,0,16"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                                        <Separator/>

                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="105"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Type"
                                   FontWeight="SemiBold"/>

                                            <TextBlock x:Name="SelectedMediaTypeText"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   TextWrapping="Wrap"/>

                                            <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,10,0,0"
                                   Text="Date taken"
                                   FontWeight="SemiBold"/>

                                            <TextBlock x:Name="SelectedDateTakenText"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>

                                            <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,10,0,0"
                                   Text="Camera"
                                   FontWeight="SemiBold"/>

                                            <TextBlock x:Name="SelectedCameraText"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>

                                            <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Margin="0,10,0,0"
                                   Text="Resolution"
                                   FontWeight="SemiBold"/>

                                            <TextBlock x:Name="SelectedResolutionText"
                                   Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"/>

                                            <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Margin="0,10,0,0"
                                   Text="File size"
                                   FontWeight="SemiBold"/>

                                            <TextBlock x:Name="SelectedFileSizeText"
                                   Grid.Row="4"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"/>

                                            <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Margin="0,10,0,0"
                                   Text="Location"
                                   FontWeight="SemiBold"/>

                                            <TextBlock x:Name="SelectedLocationText"
                                   Grid.Row="5"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>

                                            <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Margin="0,10,0,0"
                                   Text="Status"
                                   FontWeight="SemiBold"/>

                                            <TextBlock x:Name="SelectedStatusText"
                                   Grid.Row="6"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>

                                            <TextBlock Grid.Row="7"
                                   Grid.Column="0"
                                   Margin="0,10,0,0"
                                   Text="Media ID"
                                   FontWeight="SemiBold"/>

                                            <TextBlock x:Name="SelectedMediaIdText"
                                   Grid.Row="7"
                                   Grid.Column="1"
                                   Margin="0,10,0,0"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
    </StackPanel>
</Border>
        <!-- Main content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="30">
                <Border Style="{StaticResource CardBorderStyle}"
                        Width="760"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <StackPanel>
                        <TextBlock Text="Scan Your Media Library"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Margin="0,8,0,20"
                                   Text="Choose a folder and scan it for supported photos and videos."
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>

                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14"
                                Margin="0,0,0,20">
                            <TextBlock
                                Text="Supported photos: JPG, JPEG, PNG, BMP, GIF, TIFF, WEBP, HEIC&#x0a;Supported videos: MP4, MOV, AVI, MKV, WMV"
                                FontSize="13"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                TextAlignment="Center"
                                TextWrapping="Wrap"/>
                        </Border>

                        <!-- Folder selection -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <Button x:Name="SelectFolderButton"
                                    Width="210"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Select Photo Folder"
                                    Click="SelectPhotoFolder_Click"/>

                            <Button x:Name="StartScanButton"
                                    Width="150"
                                    Height="46"
                                    Margin="12,0,0,0"
                                    Content="Start Scan"
                                    IsEnabled="False"
                                    Click="StartScan_Click"/>

                            <Button x:Name="CancelScanButton"
                                    Width="120"
                                    Height="46"
                                    Margin="12,0,0,0"
                                    Content="Cancel"
                                    IsEnabled="False"
                                    Click="CancelScan_Click"/>

                            <Button x:Name="FindDuplicatesButton"
                                    Width="160"
                                    Height="46"
                                    Margin="12,0,0,0"
                                    Content="Find Duplicates"
                                    IsEnabled="False"
                                    Click="FindDuplicates_Click"/>
                        </StackPanel>

                        <!-- Selected folder -->
                        <Border Margin="0,24,0,0"
                                Padding="16"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Background="#FAFAFA">

                            <StackPanel>
                                <TextBlock Text="Selected folder"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>

                                <TextBlock x:Name="SelectedFolderText"
                                           Margin="0,6,0,0"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="No valid folder selected"/>
                            </StackPanel>
                        </Border>

                        <!-- Progress -->
                        <ProgressBar x:Name="ScanProgressBar"
                                     Margin="0,22,0,0"
                                     Height="14"
                                     IsIndeterminate="False"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"/>

                        <TextBlock x:Name="CurrentFileText"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="No scan running"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Counters -->
                        <Grid Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="#F8FAFC">
                                <StackPanel>
                                    <TextBlock Text="Processed"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="ProcessedCountText"
                                               Text="0"
                                               FontSize="22"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="8,0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="#F8FAFC">
                                <StackPanel>
                                    <TextBlock Text="Photos"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="PhotoCountText"
                                               Text="0"
                                               FontSize="22"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Margin="8,0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="#F8FAFC">
                                <StackPanel>
                                    <TextBlock Text="Videos"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="VideoCountText"
                                               Text="0"
                                               FontSize="22"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3"
                                    Margin="8,0,0,0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="#F8FAFC">
                                <StackPanel>
                                    <TextBlock Text="Unsupported"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="UnsupportedCountText"
                                               Text="0"
                                               FontSize="22"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Exact duplicate summary -->
                        <Border Margin="0,22,0,0"
        Padding="16"
        BorderBrush="{StaticResource AppBorderBrush}"
        BorderThickness="1"
        CornerRadius="10"
        Background="{StaticResource CardBackgroundBrush}">

                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Exact Duplicate Detection"
                           FontSize="17"
                           FontWeight="SemiBold"/>

                                        <TextBlock x:Name="DuplicateStatusText"
                           Margin="0,4,0,0"
                           Text="Run a scan before searching for duplicates."
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </DockPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                    Margin="0,0,8,0"
                    Padding="12"
                    Background="#F8FAFC"
                    CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Groups"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                                            <TextBlock x:Name="DuplicateGroupCountText"
                               Text="0"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                    Margin="8,0"
                    Padding="12"
                    Background="#F8FAFC"
                    CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Duplicate files"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                                            <TextBlock x:Name="DuplicateFileCountText"
                               Text="0"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                    Margin="8,0"
                    Padding="12"
                    Background="#F8FAFC"
                    CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Files hashed"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                                            <TextBlock x:Name="DuplicateFilesHashedText"
                               Text="0"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="3"
                    Margin="8,0,0,0"
                    Padding="12"
                    Background="#F8FAFC"
                    CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Recoverable"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                                            <TextBlock x:Name="RecoverableSpaceText"
                               Text="0 bytes"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- Metadata preview -->
                        <Border Margin="0,24,0,0"
        Padding="16"
        BorderBrush="{StaticResource AppBorderBrush}"
        BorderThickness="1"
        CornerRadius="10"
        Background="{StaticResource CardBackgroundBrush}">

                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock DockPanel.Dock="Left"
                       Text="Metadata Preview"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                                    <TextBlock x:Name="MetadataPreviewCountText"
                       Text="No metadata loaded"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
                                </DockPanel>

                                <DataGrid x:Name="MetadataPreviewGrid"
                  Height="260"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  AlternatingRowBackground="#F8FAFC">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="File"
                                    Binding="{Binding FileName}"
                                    Width="2*"/>

                                        <DataGridTextColumn Header="Type"
                                    Binding="{Binding MediaType}"
                                    Width="80"/>

                                        <DataGridTextColumn Header="Date taken"
                                    Binding="{Binding DateTaken}"
                                    Width="130"/>

                                        <DataGridTextColumn Header="Camera"
                                    Binding="{Binding Camera}"
                                    Width="150"/>

                                        <DataGridTextColumn Header="Resolution"
                                    Binding="{Binding Resolution}"
                                    Width="105"/>

                                        <DataGridTextColumn Header="GPS"
                                    Binding="{Binding Gps}"
                                    Width="65"/>

                                        <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Status -->
        <StatusBar Grid.Row="2"
                   Background="{StaticResource CardBackgroundBrush}">
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </StatusBar>
    </Grid>
</Window>