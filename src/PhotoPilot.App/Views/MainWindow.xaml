<Window x:Class="PhotoPilot.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhotoPilot"
        Width="1200"
        Height="750"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="📸 PhotoPilot"
                   FontSize="28"
                   FontWeight="Bold"/>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="620">

            <TextBlock Text="Welcome to PhotoPilot"
                       FontSize="30"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

            <TextBlock Margin="0,10,0,16"
                       Text="Organize memories intelligently."
                       FontSize="16"
                       HorizontalAlignment="Center"/>

            <TextBlock Margin="0,0,0,20"
                       Text="Expected media files: JPG, JPEG, PNG, BMP, GIF, TIFF, WEBP, HEIC, MP4, MOV, AVI, MKV, WMV"
                       FontSize="13"
                       Foreground="#666666"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>

            <Button Width="220"
                    Height="45"
                    Content="Select Photo Folder"
                    Click="SelectPhotoFolder_Click"/>

            <Border Margin="0,24,0,0"
                    Padding="14"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Selected folder"
                               FontWeight="SemiBold"
                               FontSize="13"/>

                    <TextBlock x:Name="SelectedFolderText"
                               Margin="0,6,0,0"
                               FontSize="14"
                               TextWrapping="Wrap"
                               Text="No valid folder selected"/>

                    <TextBlock x:Name="MediaCountText"
                               Margin="0,10,0,0"
                               FontSize="13"
                               Foreground="#666666"
                               Text="Media files found: 0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <StatusBar Grid.Row="2">
            <TextBlock x:Name="StatusText"
                       Text="Ready"/>
        </StatusBar>
    </Grid>
</Window>