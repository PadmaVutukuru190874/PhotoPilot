<Window x:Class="PhotoPilot.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhotoPilot"
        Width="1200"
        Height="750"
        MinWidth="950"
        MinHeight="650"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="86"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="30,0">

            <DockPanel VerticalAlignment="Center">
                <TextBlock DockPanel.Dock="Left"
                           Text="📸 PhotoPilot"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"/>

                <TextBlock Text="Organize memories intelligently"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="30">
                <Border Style="{StaticResource CardBorderStyle}"
                        Width="760"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <StackPanel>
                        <TextBlock Text="Scan Your Media Library"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Margin="0,8,0,20"
                                   Text="Choose a folder and scan it for supported photos and videos."
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>

                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14"
                                Margin="0,0,0,20">
                            <TextBlock
                                Text="Supported photos: JPG, JPEG, PNG, BMP, GIF, TIFF, WEBP, HEIC&#x0a;Supported videos: MP4, MOV, AVI, MKV, WMV"
                                FontSize="13"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                TextAlignment="Center"
                                TextWrapping="Wrap"/>
                        </Border>

                        <!-- Folder selection -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <Button x:Name="SelectFolderButton"
                                    Width="210"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Select Photo Folder"
                                    Click="SelectPhotoFolder_Click"/>

                            <Button x:Name="StartScanButton"
                                    Width="150"
                                    Height="46"
                                    Margin="12,0,0,0"
                                    Content="Start Scan"
                                    IsEnabled="False"
                                    Click="StartScan_Click"/>

                            <Button x:Name="CancelScanButton"
                                    Width="120"
                                    Height="46"
                                    Margin="12,0,0,0"
                                    Content="Cancel"
                                    IsEnabled="False"
                                    Click="CancelScan_Click"/>
                        </StackPanel>

                        <!-- Selected folder -->
                        <Border Margin="0,24,0,0"
                                Padding="16"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Background="#FAFAFA">

                            <StackPanel>
                                <TextBlock Text="Selected folder"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>

                                <TextBlock x:Name="SelectedFolderText"
                                           Margin="0,6,0,0"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="No valid folder selected"/>
                            </StackPanel>
                        </Border>

                        <!-- Progress -->
                        <ProgressBar x:Name="ScanProgressBar"
                                     Margin="0,22,0,0"
                                     Height="14"
                                     IsIndeterminate="False"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"/>

                        <TextBlock x:Name="CurrentFileText"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="No scan running"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Counters -->
                        <Grid Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="#F8FAFC">
                                <StackPanel>
                                    <TextBlock Text="Processed"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="ProcessedCountText"
                                               Text="0"
                                               FontSize="22"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="8,0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="#F8FAFC">
                                <StackPanel>
                                    <TextBlock Text="Photos"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="PhotoCountText"
                                               Text="0"
                                               FontSize="22"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Margin="8,0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="#F8FAFC">
                                <StackPanel>
                                    <TextBlock Text="Videos"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="VideoCountText"
                                               Text="0"
                                               FontSize="22"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3"
                                    Margin="8,0,0,0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="#F8FAFC">
                                <StackPanel>
                                    <TextBlock Text="Unsupported"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="UnsupportedCountText"
                                               Text="0"
                                               FontSize="22"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <!-- Metadata preview -->
                        <Border Margin="0,24,0,0"
        Padding="16"
        BorderBrush="{StaticResource AppBorderBrush}"
        BorderThickness="1"
        CornerRadius="10"
        Background="{StaticResource CardBackgroundBrush}">

                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock DockPanel.Dock="Left"
                       Text="Metadata Preview"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                                    <TextBlock x:Name="MetadataPreviewCountText"
                       Text="No metadata loaded"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
                                </DockPanel>

                                <DataGrid x:Name="MetadataPreviewGrid"
                  Height="260"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  AlternatingRowBackground="#F8FAFC">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="File"
                                    Binding="{Binding FileName}"
                                    Width="2*"/>

                                        <DataGridTextColumn Header="Type"
                                    Binding="{Binding MediaType}"
                                    Width="80"/>

                                        <DataGridTextColumn Header="Date taken"
                                    Binding="{Binding DateTaken}"
                                    Width="130"/>

                                        <DataGridTextColumn Header="Camera"
                                    Binding="{Binding Camera}"
                                    Width="150"/>

                                        <DataGridTextColumn Header="Resolution"
                                    Binding="{Binding Resolution}"
                                    Width="105"/>

                                        <DataGridTextColumn Header="GPS"
                                    Binding="{Binding Gps}"
                                    Width="65"/>

                                        <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Status -->
        <StatusBar Grid.Row="2"
                   Background="{StaticResource CardBackgroundBrush}">
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </StatusBar>
    </Grid>
</Window>