<Window x:Class="PhotoPilot.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhotoPilot"
        Width="1200"
        Height="750"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="86"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="30,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock Text="📸 PhotoPilot"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           DockPanel.Dock="Left"/>

                <TextBlock Text="Organize memories intelligently"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="30">
            <Border Style="{StaticResource CardBorderStyle}"
                    Width="700"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Welcome to PhotoPilot"
                               FontSize="32"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <TextBlock Margin="0,10,0,22"
                               Text="Select a folder that contains photos or videos to begin."
                               FontSize="16"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>

                    <Border Background="#EFF6FF"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14"
                            Margin="0,0,0,22">
                        <TextBlock Text="Expected media files: JPG, JPEG, PNG, BMP, GIF, TIFF, WEBP, HEIC, MP4, MOV, AVI, MKV, WMV"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Button Width="240"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Select Photo Folder"
                            Click="SelectPhotoFolder_Click"
                            HorizontalAlignment="Center"/>

                    <Border Margin="0,26,0,0"
                            Padding="16"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Background="#FAFAFA">
                        <StackPanel>
                            <TextBlock Text="Selected folder"
                                       FontWeight="SemiBold"
                                       FontSize="13"/>

                            <TextBlock x:Name="SelectedFolderText"
                                       Margin="0,6,0,0"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="No valid folder selected"/>

                            <TextBlock x:Name="MediaCountText"
                                       Margin="0,10,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Media files found: 0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2"
                   Background="{StaticResource CardBackgroundBrush}">
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </StatusBar>
    </Grid>
</Window>