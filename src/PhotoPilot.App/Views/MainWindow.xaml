<Window x:Class="PhotoPilot.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhotoPilot"
        Width="1200"
        Height="750"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📸 PhotoPilot"
                   FontSize="28"
                   FontWeight="Bold"/>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="Welcome to PhotoPilot"
                       FontSize="30"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

            <TextBlock Margin="0,10,0,25"
                       Text="Organize memories intelligently."
                       FontSize="16"
                       HorizontalAlignment="Center"/>

            <Button Width="220"
                    Height="45"
                    Content="Select Photo Folder"/>
        </StackPanel>

        <StatusBar Grid.Row="2">
            <TextBlock Text="Ready"/>
        </StatusBar>
    </Grid>
</Window>