<UserControl x:Class="PhotoPilot.App.Views.Controls.LibraryCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="220"
             MinHeight="290">

    <Border Margin="8"
            Padding="0"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="170"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Thumbnail area -->
            <Border Grid.Row="0"
                    Background="#EEF2F7"
                    CornerRadius="12,12,0,0"
                    ClipToBounds="True">

                <Grid>
                    <Image Source="{Binding ThumbnailPath}"
                           Stretch="UniformToFill">

                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility"
                                        Value="Visible"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasThumbnail}"
                                                 Value="False">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <!-- Placeholder -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasThumbnail}"
                                                 Value="False">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="📷"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Margin="0,6,0,0"
                                   Text="Preview unavailable"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Media type badge -->
                    <Border Margin="10"
                            Padding="8,4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="#CCFFFFFF"
                            CornerRadius="8">

                        <TextBlock Text="{Binding MediaType}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Information area -->
            <StackPanel Grid.Row="1"
                        Margin="14,12,14,14">

                <TextBlock Text="{Binding FileName}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding FilePath}"/>

                <TextBlock Margin="0,8,0,0"
                           Text="{Binding DateTaken, StringFormat=Date: {0}}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Margin="0,4,0,0"
                           Text="{Binding Camera, StringFormat=Camera: {0}}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Margin="0,4,0,0"
                           Text="{Binding Resolution, StringFormat=Resolution: {0}}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

                <DockPanel Margin="0,10,0,0">
                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding FileSize}"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <TextBlock HorizontalAlignment="Right"
                               Text="{Binding ProcessingStatus}"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </DockPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>